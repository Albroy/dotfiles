# based on https://gist.github.com/bahamas10
if [ "$(tput colors)" -ge 256 ]; then
  COLOR=135
else
  COLOR=1
fi
set -a
# Blinking text (usually not supported → use bold instead)
LESS_TERMCAP_mb="$(tput bold)$(tput setaf "$COLOR")"

# Bold text (section titles in man pages)
LESS_TERMCAP_md="$(tput bold)$(tput setaf "$COLOR")"

# Reset all styles
LESS_TERMCAP_me=$(tput sgr0)

# End standout mode
LESS_TERMCAP_se=$(tput sgr0)

# Standout mode (search results in less)
# → bold + yellow text + blue background
LESS_TERMCAP_so="$(tput bold)$(tput setaf 3)$(tput setab 4)"

# End underline
LESS_TERMCAP_ue=$(tput sgr0)

# Underline mode
# → underline + bold + green text
LESS_TERMCAP_us="$(tput smul)$(tput bold)$(tput setaf 2)"

# Reverse colors (swap foreground/background)
LESS_TERMCAP_mr=$(tput rev)

# Dim text (less visible)
LESS_TERMCAP_mh=$(tput dim)

MANPAGER='less'
set +a
