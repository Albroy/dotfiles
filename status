#!/usr/bin/env bash

# Read-only health check for this dotfiles repo.
# For every dotbot config in meta/configs/*.yaml it reports, in a table: symlink & install 

CONFIG_SUFFIX=".yaml"
META_DIR="meta"
CONFIG_DIR="configs"

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIGS_DIR="${BASE_DIR}/${META_DIR}/${CONFIG_DIR}"
PYYAML_VENDOR="${BASE_DIR}/${META_DIR}/dotbot/lib/pyyaml/lib"

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    RED=$'\e[31m'; GRN=$'\e[32m'; YEL=$'\e[33m'
    DIM=$'\e[2m'; BLD=$'\e[1m'; RST=$'\e[0m'
else
    RED=""; GRN=""; YEL=""; DIM=""; BLD=""; RST=""
fi

if command -v rpm >/dev/null 2>&1; then
    PKG_MGR="rpm"
    pkg_installed() { rpm -q --whatprovides "$1" >/dev/null 2>&1; }
elif command -v dpkg >/dev/null 2>&1; then
    PKG_MGR="dpkg"
    pkg_installed() { dpkg -s "$1" >/dev/null 2>&1; }
else
    PKG_MGR="none"
    pkg_installed() { return 2; }
fi

parse_config() {
    PYYAML_VENDOR="$PYYAML_VENDOR" python3 - "$1" <<'PY'
import os, sys
try:
    import yaml
except ImportError:
    sys.path.insert(0, os.environ.get("PYYAML_VENDOR", ""))
    import yaml

with open(sys.argv[1]) as fh:
    data = yaml.safe_load(fh) or []

for item in data:
    if not isinstance(item, dict):
        continue
    for tgt, val in (item.get("link") or {}).items():
        src = val.get("path", "") if isinstance(val, dict) else val
        if src:
            print("LINK\t%s\t%s" % (tgt, src))
    for sub in (item.get("omnipkg") or []):
        if not isinstance(sub, dict):
            continue
        for pkg in (sub.get("install") or []):
            if isinstance(pkg, list):            # alternatives
                name = "|".join(str(x) for x in pkg)
            elif isinstance(pkg, dict):          # per-platform / per-manager
                name = "|".join(str(x) for x in pkg.values())
            else:
                name = str(pkg)
            if name:
                print("PKG\t%s" % name)
PY
}

link_state() {  # args: target source -> echoes state keyword
    local target="$1" source="$2" t dest exp
    t="${target/#\~/$HOME}"
    if [ -L "$t" ]; then
        if [ ! -e "$t" ]; then echo "broken"; return; fi
        dest=$(readlink -f "$t")
        exp=$(readlink -f "${BASE_DIR}/${source}")
        if [ "$dest" = "$exp" ]; then echo "OK"; else echo "elsewhere"; fi
    elif [ -e "$t" ]; then
        echo "conflict"
    else
        echo "absent"
    fi
}

color_link() {
    case "$1" in
        OK)       printf '%s' "$GRN" ;;
        absent)   printf '%s' "$YEL" ;;
        *)        printf '%s' "$RED" ;;   # conflict / elsewhere / broken
    esac
}

declare -a CONFIGS=()
if [ $# -gt 0 ]; then
    for c in "$@"; do
        c=${c%-sudo}
        if [ -f "${CONFIGS_DIR}/${c}${CONFIG_SUFFIX}" ]; then
            CONFIGS+=("$c")
        else
            echo "${RED}unknown config: $c${RST}" >&2
        fi
    done
else
    for f in "${CONFIGS_DIR}"/*"${CONFIG_SUFFIX}"; do
        CONFIGS+=("$(basename "$f" "${CONFIG_SUFFIX}")")
    done
fi
[ ${#CONFIGS[@]} -eq 0 ] && { echo "no configs to check" >&2; exit 1; }

ok=0; bad=0; warn=0; pkg_ok=0; pkg_bad=0; pkg_unk=0

render() {
    printf '%s%-12s %-34s %s%s\n' "$BLD" "CONFIG" "SYMLINK" "STATE" "$RST"
    printf '%s%s%s\n' "$DIM" "$(printf '%.0s-' {1..60})" "$RST"
    for cfg in "${CONFIGS[@]}"; do
        while IFS=$'\t' read -r kind a b; do
            [ "$kind" = "LINK" ] || continue
            st=$(link_state "$a" "$b")
            case "$st" in OK) ok=$((ok+1));; absent) warn=$((warn+1));; *) bad=$((bad+1));; esac
            printf '%-12s %-34s %s%s%s\n' "$cfg" "$a" "$(color_link "$st")" "$st" "$RST"
        done < <(parse_config "${CONFIGS_DIR}/${cfg}${CONFIG_SUFFIX}")
    done

    echo
    printf '%s%-12s %-34s %s%s\n' "$BLD" "CONFIG" "PACKAGE ($PKG_MGR)" "STATE" "$RST"
    printf '%s%s%s\n' "$DIM" "$(printf '%.0s-' {1..60})" "$RST"
    for cfg in "${CONFIGS[@]}"; do
        while IFS=$'\t' read -r kind a _; do
            [ "$kind" = "PKG" ] || continue
            found=0
            IFS='|' read -ra alts <<< "$a"
            for p in "${alts[@]}"; do pkg_installed "$p" && { found=1; break; }; done
            if [ "$found" = 1 ]; then
                st="installed"; col="$GRN"; pkg_ok=$((pkg_ok+1))
            elif [ "$PKG_MGR" = "none" ]; then
                st="?"; col="$DIM"; pkg_unk=$((pkg_unk+1))
            else
                st="missing"; col="$RED"; pkg_bad=$((pkg_bad+1))
            fi
            printf '%-12s %-34s %s%s%s\n' "$cfg" "$a" "$col" "$st" "$RST"
        done < <(parse_config "${CONFIGS_DIR}/${cfg}${CONFIG_SUFFIX}")
    done

    echo
    printf '%slinks%s   %s%d OK%s  %s%d absent%s  %s%d problem%s\n' \
        "$BLD" "$RST" "$GRN" "$ok" "$RST" "$YEL" "$warn" "$RST" "$RED" "$bad" "$RST"
    printf '%spkgs%s    %s%d installed%s  %s%d missing%s%s\n' \
        "$BLD" "$RST" "$GRN" "$pkg_ok" "$RST" "$RED" "$pkg_bad" "$RST" \
        "$( [ "$pkg_unk" -gt 0 ] && printf '  %s%d ?%s' "$DIM" "$pkg_unk" "$RST" )"

    return $(( (bad + pkg_bad) > 0 ? 1 : 0 ))
}

out=$(mktemp)
render >"$out"; rc=$?
if [ -t 1 ] && [ -z "${NO_PAGER:-}" ] && command -v less >/dev/null 2>&1; then
    less -FR "$out"
else
    cat "$out"
fi
rm -f "$out"
exit "$rc"
